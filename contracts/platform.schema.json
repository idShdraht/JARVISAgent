{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "version": {
            "type": "string"
        },
        "arch": {
            "type": "string"
        },
        "platform": {
            "type": "string"
        },
        "gateway_port": {
            "type": "number"
        },
        "nodeVersion": {
            "type": "string"
        },
        "features": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "version",
        "arch",
        "platform",
        "gateway_port",
        "nodeVersion",
        "features"
    ],
    "additionalProperties": false
}